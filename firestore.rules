rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isUser(uid) {
      return request.auth.uid == uid;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return getRole() == 'admin' || getRole() == 'singularity';
    }

    function isModerator() {
      return getRole() == 'moderator' || isAdmin();
    }

    // --- COLLECTION RULES ---

    // Users: Users can read their own data. Users can update their own data excluding sensitive fields unless Admin.
    match /users/{uid} {
      allow read: if isUser(uid) || isAdmin();
      allow create: if isUser(uid) || isAdmin();
      allow update: if (isUser(uid) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isPremium', 'skillStats'])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Hub Topics: Publicly readable. Only Admins can forge.
    match /hub_topics/{topicId} {
      allow read, list, get: if true;
      allow write: if isAdmin();
    }

    // Config (Broadcasts): Publicly readable. Only Admins can update.
    match /config/broadcast {
      allow read, get: if true;
      allow write: if isAdmin();
    }

    // Audit Logs: Immutable. Only Admins can read. No one can delete/update.
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // Service level logging
      allow update, delete: if false;
    }

    // Quizzes & Roadmaps: Private to user unless Admin.
    match /roadmaps/{docId} {
      allow read, write: if isUser(resource.data.userId) || isAdmin();
    }
    
    match /quizzes/{docId} {
      allow read, write: if isUser(resource.data.userId) || isAdmin();
    }

    // Knowledge Vault: Public read for auth users, backend-only write.
    match /vault/{document=**} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions / Admin SDK can write
    }

    // Flagged Simulations: Moderators and Admins only.
    match /flagged_simulations/{simId} {
      allow read, write: if isModerator();
    }
  }
}
